{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "node scripts/railway-service.js build"
  },
  "deploy": {
    "preDeployCommand": "node scripts/railway-service.js migrate",
    "startCommand": "node scripts/railway-service.js start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
