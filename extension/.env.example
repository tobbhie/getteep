# Funding links
# Staging phase:
# - Keep Arc beta/test funds on FUNDING_ENV=arcTestnet.
# - Use FUNDING_ENV=crossmintStaging only for Crossmint staging integration tests.
# - Production should move to FUNDING_ENV=arcMainnet only after provider and compliance signoff.
FUNDING_ENV=arcTestnet
FAUCET_URL=https://faucet.circle.com
ENABLE_FIAT_ONRAMP=false
ENABLE_FIAT_OFFRAMP=false
# Crossmint staging URL templates may include WALLET, WALLET_ADDRESS, {wallet}, or {walletAddress}.
# Leave ONRAMP_URL/OFFRAMP_URL empty when using backend-created Crossmint orders.
ONRAMP_URL=
OFFRAMP_URL=

# Release defaults
DEBUG_TEEP=false
DEBUG_TIPCOIN=false
BLUR_EMAIL=false
