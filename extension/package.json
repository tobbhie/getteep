{
  "name": "@teep/extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "build:prod": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:debug": "cross-env DEBUG_TEEP=true ALLOW_INSECURE_EXTENSION_BUILD=true webpack --mode production",
    "build:demo": "cross-env BLUR_EMAIL=true webpack --mode production",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.15.0",
    "@teep/shared": "file:../shared",
    "buffer": "^6.0.3",
    "ethers": "^6.13.0",
    "permissionless": "^0.2.47",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.277",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "copy-webpack-plugin": "^12.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.0",
    "rimraf": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
