# Server
PORT=3001
CORS_ORIGIN=http://localhost:5174
# Optional comma-separated extras for production previews or the published extension ID.
# Example: CORS_ORIGINS=https://getteep.xyz,https://www.getteep.xyz
CORS_ORIGINS=
# Example after Chrome Web Store publish: chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef
CHROME_EXTENSION_ORIGINS=
JSON_BODY_LIMIT=64kb
TRUST_PROXY=false
WEB_APP_URL=http://localhost:5174
RECEIPT_BASE_URL=http://localhost:5174
# Optional: serve the built web app from backend for crawler-visible profile metadata.
# Defaults try ../web/dist and web/dist.
WEB_DIST_DIR=../web/dist
OPS_TOKEN=
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=30
WRITE_RATE_LIMIT_MAX=60
WITHDRAWAL_RATE_LIMIT_MAX=10

# Debug: set to true to log claim-wallet-status and other auth flows (backend console)
# DEBUG_TEEP=true

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/teep
# POSTGRES_URL can be used instead of DATABASE_URL by hosted providers.
# POSTGRES_URL=
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECT_TIMEOUT_MS=10000
# Set true only when your provider requires SSL.
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# Chain (arcTestnet, base, or baseSepolia)
CHAIN=arcTestnet
CHAIN_ID=5042002
RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network

# Arc Testnet ERC-20 USDC. Native gas is also USDC but uses 18 decimals.
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Contract addresses (from deployment)
TIP_CONTRACT_ADDRESS=0xFAF11e9b2242927E996f0ff6a0239Da2B742893C
FACTORY_ADDRESS=0x7acd5485C975649626bF379710f57021C097115b
X_TIPPING_ROUTER_ADDRESS=

# Indexer
POLL_INTERVAL_MS=5000
INDEXER_BATCH_SIZE=5000
# Set this to the TipContract deployment block so a fresh DB backfills from deployment,
# not from "latest minus a small window".
INDEXER_START_BLOCK=0
# Number of latest blocks to wait before indexing, to reduce reorg/race surprises.
INDEXER_CONFIRMATIONS=2
# Re-scan this many recent indexed blocks each poll to recover from transient RPC misses.
INDEXER_RESCAN_BLOCKS=100
# Emergency recovery switch: true rewinds the DB state to INDEXER_START_BLOCK on boot.
INDEXER_RESET_TO_START_ON_BOOT=false
# RPC request timeout in ms (default 30000). Increase if Alchemy/network is slow.
RPC_TIMEOUT_MS=30000
# Local development only: set true if Node cannot verify the Arc RPC certificate chain.
# Prefer fixing local CA trust or NODE_EXTRA_CA_CERTS. Production startup blocks this flag.
ALLOW_INSECURE_RPC_TLS=false
# Local development only: set true if Node cannot verify X/CDN avatar certificates.
# Prefer fixing local CA trust or NODE_EXTRA_CA_CERTS. Production startup blocks this flag.
ALLOW_INSECURE_AVATAR_TLS=false
ALLOW_INSECURE_OEMBED_TLS=false
INDEXER_MAX_LAG_BLOCKS=50
INDEXER_MAX_STALE_MS=300000

# Abuse heuristics
ABUSE_HIGH_FREQUENCY_TIP_COUNT=25
ABUSE_CIRCULAR_TIP_WINDOW_SECONDS=604800
ABUSE_WASH_REFERRAL_WINDOW_SECONDS=1209600

# Attestation signing key (KEEP SECRET)
ATTESTATION_PRIVATE_KEY=0x...
ATTESTATION_EXPIRY_SECONDS=600
# Optional separate signer for ClaimWallet withdrawals to non-owner destinations.
# Defaults to ATTESTATION_PRIVATE_KEY when unset.
WITHDRAWAL_AUTHORIZATION_PRIVATE_KEY=

# X (Twitter) OAuth 2.0
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3001/auth/x/callback
# App-only bearer token for resolving X handles to stable numeric user IDs before tips.
X_BEARER_TOKEN=

# X bot / on-chain relayed tipping
X_AGENT_TOKEN=
X_BOT_USERNAME=teep_app
X_BOT_USER_ID=
X_TIPPING_RELAYER_PRIVATE_KEY=
X_BOT_MIN_TIP_RAW=10000
X_BOT_MAX_PER_TIP_RAW=10000000
X_BOT_MAX_DAILY_RAW=50000000
X_BOT_PROCESSING_STALE_MS=300000
# Optional: treasury address for Teep balance deposits (onchain watcher — step 7)
TEEP_BALANCE_TREASURY_ADDRESS=

# Privy server API credentials. Required for deleting a Teep account from the settings page.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Withdrawal fee & referral (virality MVP)
PROTOCOL_TREASURY_ADDRESS=0x...
WITHDRAWAL_FEE_BPS=500
REFERRER_SHARE_BPS=3000
REFERRAL_ACTIVATION_MIN_TIPS=1
REFERRAL_CAP_PER_REFERRER=100

# Withdrawal safeguards
# Default: $1,000/day at 6 USDC decimals. Set per launch/risk appetite.
WITHDRAWAL_DAILY_LIMIT_RAW=1000000000
WITHDRAWAL_REQUIRE_EMAIL_CONFIRMATION=true
WITHDRAWAL_CONFIRMATION_TTL_MS=600000
# Production should point this to an internal email service/webhook.
# In local dev, if this is unset the API returns devCode for testing.
WITHDRAWAL_EMAIL_WEBHOOK_URL=

# EIP-712 setReferrer (required when ReferralRegistry is deployed)
REFERRAL_REGISTRY_ADDRESS=0x9FFD4f2429A7d8484B6920a01653Ac61Fa40d134
REFERRAL_SIGNER_PRIVATE_KEY=0x...   # or leave unset to use ATTESTATION_PRIVATE_KEY
ALLOW_UNSIGNED_REFERRAL_WRITES=false
ALLOW_UNSIGNED_ATTESTATION=false

# Dev/testnet only. Do not enable in production.
ENABLE_FAUCET=false
FAUCET_PRIVATE_KEY=
# Dev-only optimistic activity rows. Production history should come from indexed chain events.
ALLOW_CLIENT_ACTIVITY_WRITES=false

# DeFi / Grow Tips beta
# Default is preview-only. Transaction preparation and signing routes must stay disabled until
# provider addresses, bridge routes, risk copy, and recovery flows are verified.
ENABLE_DEFI_TRANSACTIONS=false
DEFI_MIN_DEPOSIT_RAW=1000000
DEFI_MORPHO_PREVIEW_APY=4.8
DEFI_COMMUNITY_TOTAL_RAW=128500000000
DEFI_PARTICIPANT_COUNT=34
DEFI_MORPHO_DESTINATION_CHAIN_ID=84532
DEFI_MORPHO_DESTINATION_CHAIN_NAME=Base Sepolia
# Optional JSON array overriding the built-in preview strategies. Keep provider metadata here
# instead of hardcoding frontend flows.
DEFI_STRATEGIES_JSON=

# Morpho provider metadata. Leave empty until Arc/Base test deployments are verified.
MORPHO_API_URL=https://api.morpho.org/graphql
MORPHO_VAULT_ADDRESS=
MORPHO_VAULT_VERSION=v2
MORPHO_VAULT_ASSET_ADDRESS=
MORPHO_BUNDLER_ADDRESS=
MORPHO_GENERAL_ADAPTER_ADDRESS=

# Circle / Arc App Kit bridge metadata for future cross-chain strategies.
CIRCLE_APP_KIT_API_KEY=
CCTP_SOURCE_DOMAIN=26
CCTP_DESTINATION_DOMAIN=
CCTP_TOKEN_MESSENGER_ADDRESS=
CCTP_MESSAGE_TRANSMITTER_ADDRESS=
CCTP_DESTINATION_USDC_ADDRESS=
CROSS_CHAIN_STRATEGY_MAX_PENDING_MS=1800000
