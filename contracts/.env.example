# Deployer private key (DO NOT COMMIT)
DEPLOYER_PRIVATE_KEY=0x...

# Base Sepolia (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet
BASE_RPC_URL=https://mainnet.base.org

# BaseScan API key for contract verification
BASESCAN_API_KEY=

# Attestation signer address (backend's signing wallet)
ATTESTATION_SIGNER_ADDRESS=0x...

# ReferralRegistry (used by deploy and deploy-referral-only)
PROTOCOL_TREASURY_ADDRESS=0x...
WITHDRAWAL_FEE_BPS=500
REFERRER_SHARE_BPS=3000
# Optional: different signer for setReferrer (defaults to ATTESTATION_SIGNER_ADDRESS)
# REFERRAL_SIGNER_ADDRESS=0x...

# For deploy-referral-only.ts only: existing factory to attach registry to
# FACTORY_ADDRESS=0x...

# USDC address
# Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia: deploy MockUSDC or use a test token
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
