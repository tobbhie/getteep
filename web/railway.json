{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run web:build:prod"
  },
  "deploy": {
    "startCommand": "npm run preview --workspace=web -- --host 0.0.0.0 --port ${PORT}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
